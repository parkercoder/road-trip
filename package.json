{
  "name": "road-trip-map",
  "version": "1.0.0",
  "description": "An end-to-end TripPlan Builder and mobile-first road trip Traveler.",
  "license": "MIT",
  "private": false,
  "scripts": {
    "serve": "python3 -m http.server 8765",
    "build:routes": "node scripts/build-road-routes.mjs",
    "test": "node --test tests/*.test.mjs",
    "check:tripplan": "node scripts/check-trip-spec.mjs examples/lakes-and-pines.trip.json data/cross-canada.trip.json",
    "check:tripspec": "npm run check:tripplan",
    "check:privacy": "node scripts/check-privacy.mjs"
  },
  "engines": {
    "node": ">=18"
  }
}
